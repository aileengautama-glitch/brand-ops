# Brand Ops — environment variable template
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and should never be committed.
#
# All variables MUST be prefixed VITE_ to be accessible in browser code
# via import.meta.env.VITE_*

# ── Supabase ────────────────────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → API
#
# When these variables are NOT set, the app runs fully on localStorage (current
# behaviour). Setting them enables the backend data layer without breaking
# anything — the repositories fall back to localStorage gracefully.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
